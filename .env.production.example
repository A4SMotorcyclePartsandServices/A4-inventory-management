FLASK_SECRET_KEY=replace-with-a-long-random-secret
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME_HOURS=12
MAX_CONTENT_LENGTH_MB=16

# Railway PostgreSQL values
DB_HOST=replace-with-railway-db-host
DB_PORT=5432
DB_NAME=replace-with-railway-db-name
DB_USER=replace-with-railway-db-user
DB_PASSWORD=replace-with-railway-db-password

# Conservative pool defaults for first launch
DB_POOL_MIN=1
DB_POOL_MAX=10

# App runtime
APP_THREADS=8
APP_TIMEZONE=Asia/Manila
TZ=Asia/Manila

# One-time admin seeding for a fresh database.
# Set this only when you are about to run scripts/seed_admins.py, then remove it.
ADMIN_SEED_JSON=[{"username":"replace-admin","password":"replace-with-a-strong-password"}]
